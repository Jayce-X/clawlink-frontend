<!-- Designed & Developed by OHZI Interactive Studio / https://ohzi.io--><!DOCTYPE html><html lang="en"><head><meta charset="utf-8"><meta http-equiv="X-UA-Compatible" content="IE=Edge"><meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=2.0"><meta name="title" content="OHZI Interactive Studio / Dive into digital magic."><meta name="description" content="We are a passionate team of designers and developers dedicated to building spectacular 3D, AR and VR Web interactive experiences."><link rel="canonical" href="https://ohzi.io/"><meta property="og:locale" content="en_US"><meta property="og:type" content="website"><meta property="og:title" content="OHZI Interactive Studio / Dive into digital magic."><meta property="og:description" content="We are a passionate team of designers and developers dedicated to building spectacular 3D, AR and VR Web interactive experiences."><meta property="og:url" content="https://ohzi.io/"><meta property="og:site_name" content="OHZI Interactive Studio / Dive into digital magic."><meta property="og:image" content="https://ohzi.io/banner.jpg"><meta property="og:image:secure_url" content="https://ohzi.io/banner.jpg"><meta property="twitter:card" content="summary_large_image"><meta property="twitter:description" content="We are a passionate team of designers and developers dedicated to building spectacular 3D, AR and VR Web interactive experiences."><meta property="twitter:title" content="OHZI Interactive Studio / Dive into digital magic."><meta property="twitter:image" content="https://ohzi.io/banner.jpg"><meta property="twitter:url" content="https://ohzi.io/"><meta name="theme-color" content="#111111"><title>OHZI Interactive Studio</title><link rel="icon" type="image/x-icon" href="/favicon_white.0a4bb092.png" media="(prefers-color-scheme:dark)"><link rel="icon" type="image/x-icon" href="/favicon_black.5b575407.png" media="(prefers-color-scheme:light)"><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@200..900&amp;display=swap" rel="stylesheet"><meta name="apple-mobile-web-app-title" content="OHZI"><link rel="apple-touch-icon" sizes="180x180" href="/icon_180.8eef07fd.png"><link rel="manifest" href="/assets/data/site.webmanifest"><link href="/index.8aec6d7c.css" rel="stylesheet"><!-- Google tag (gtag.js) --><script async src="https://www.googletagmanager.com/gtag/js?id=UA-136791002-1"></script><script>function gtag(){dataLayer.push(arguments)}window.dataLayer=window.dataLayer||[],gtag("js",new Date),gtag("config","UA-136791002-1"),gtag("config","AW-330743563");</script></head><body><div class="data"><h1 class="title">OHZI Interactive Studio / WebGL ThreeJS 3D, AR, VR Studio</h1><h2>Who we are: We are a 3D, AR, VR Web Experiences Studio.</h2><a href="https://ohzi.io/who-we-are" target="_blank" alt="Who we are">Who we are</a><h2>How we do it: We use WebGL, WebXR, WebGPU, ThreeJS and Blender to create 3D, AR, VR Web Experiences.</h2><a href="https://ohzi.io/how-we-do-it" target="_blank" alt="How we do it">How we do it</a><h2>Our work: We build spectacular, 3D interactive experiences for HTC, Worldbank, and more.</h2><a href="https://ohzi.io/our-work" target="_blank" alt="Our Work">Our work</a><h2>Contact: Let's create a WebGL ThreeJS 3D, AR, VR, Web Experience for your brand.</h2><a href="https://ohzi.io/contact" target="_blank" alt="Contact">Contact</a><h3 class="subtitle">We tell stories with WebGL, WebXR, ThreeJS and Blender. Let's create a 3D Web Experience for your brand.</h3><h4 class="description">We are a passionate team of designers and developers dedicated to building spectacular 3D, AR and VR Web interactive experiences.</h4><a class="labs" rel="noopener" href="https://labs.ohzi.io" target="_blank" alt="OHZI Labs">OHZI Interactive Sturio Labs: 3D Web Experiences using WebGL, ThreeJS and Blender.</a><a class="compress" rel="noopener" href="https://compress.ohzi.io" target="_blank" alt="OHZI Labs">Compress: An in-house tool to compress videos for the web.</a></div><div class="container"><div class="canvas-container"><canvas class="main-canvas"></canvas></div><div class="hidden section transition-from-section"></div><div class="hidden section transition-back"></div><div class="hidden section test"></div><div class="hidden section transition-from-menu"></div><div class="contact hidden section"><div class="button contact__astronaut_collider--desktop contact__groups" data-track="contact.astronaut"></div><div class="contact__groups"><div class="contact__group contact__group--hidden-desktop"></div><div class="contact__group contact__group--title"><div class="contact__title">WHERE WILL YOUR STORY GO NEXT?</div><div class="contact__subtitle">LET'S FIND OUT.</div></div><div class="button contact__astronaut_collider--mobile contact__group contact__group--hidden-desktop" data-track="contact.astronaut"></div><div class="contact__group"><div class="contact__label contact__label--email">GIVE US A SHOUT.</div><a class="button contact__email" href="/cdn-cgi/l/email-protection#b2dad7dededdf2dddac8db9cdbdd" onclick="app.contact_view.contact(event)" target="_blank" data-track="contact.email"><span class="__cf_email__" data-cfemail="6109040d0d0e210e091b084f080e">[email&#160;protected]</span><div class="contact__email-underline"></div></a></div><div class="contact__group contact__group--subscribe"><div class="contact__label contact__label--subscribe">SUBSCRIBE</div><div class="contact__subscribe-links"><div class="button contact__newsletter-button" onclick="app.newsletter_modal.show()">newsletter</div></div></div><div class="contact__group contact__group--social"><div class="contact__label contact__label--social">LET'S BE FRIENDS!</div><div class="contact__social-links"><a class="button contact__social-link" rel="noopener" href="https://www.instagram.com/ohzinteractive.studio" target="_blank" data-track="contact.instagram"><svg xmlns="http://www.w3.org/2000/svg" width="31.518" height="31.511" viewbox="0 0 31.518 31.511"><path d="M15.757,9.914a8.079,8.079,0,1,0,8.079,8.079A8.066,8.066,0,0,0,15.757,9.914Zm0,13.331a5.252,5.252,0,1,1,5.252-5.252,5.262,5.262,0,0,1-5.252,5.252ZM26.051,9.584A1.884,1.884,0,1,1,24.166,7.7,1.88,1.88,0,0,1,26.051,9.584ZM31.4,11.5a9.325,9.325,0,0,0-2.545-6.6,9.387,9.387,0,0,0-6.6-2.545c-2.6-.148-10.4-.148-13,0a9.373,9.373,0,0,0-6.6,2.538,9.356,9.356,0,0,0-2.545,6.6c-.148,2.6-.148,10.4,0,13a9.325,9.325,0,0,0,2.545,6.6,9.4,9.4,0,0,0,6.6,2.545c2.6.148,10.4.148,13,0a9.325,9.325,0,0,0,6.6-2.545,9.387,9.387,0,0,0,2.545-6.6c.148-2.6.148-10.392,0-12.994ZM28.041,27.281a5.318,5.318,0,0,1-3,3c-2.074.823-7,.633-9.288.633s-7.221.183-9.288-.633a5.318,5.318,0,0,1-3-3c-.823-2.074-.633-7-.633-9.288s-.183-7.221.633-9.288a5.318,5.318,0,0,1,3-3c2.074-.823,7-.633,9.288-.633s7.221-.183,9.288.633a5.318,5.318,0,0,1,3,3c.823,2.074.633,7,.633,9.288S28.863,25.214,28.041,27.281Z" transform="translate(0.005 -2.238)" fill="#fff"></path></svg></a><a class="button contact__social-link" rel="noopener" href="https://medium.com/ohzi-interactive-studio" target="_blank" data-track="contact.medium"><svg xmlns="http://www.w3.org/2000/svg" width="34.01" height="26.986" viewbox="0 0 34.01 26.986"><path d="M5.027,10.005A1.327,1.327,0,0,0,4.6,8.895L1.427,5.07V4.5h9.858l7.622,16.713L25.608,4.5h9.4v.57l-2.714,2.6a.792.792,0,0,0-.3.759V27.555a.792.792,0,0,0,.3.759l2.651,2.6v.57H21.607v-.57l2.749-2.665c.267-.267.267-.352.267-.759V12.038l-7.643,19.4H15.947l-8.887-19.4v13a1.771,1.771,0,0,0,.492,1.491l3.572,4.331v.57H1v-.562L4.57,26.529a1.713,1.713,0,0,0,.457-1.491Z" transform="translate(-0.998 -4.5)" fill="#fff"></path></svg></a><a class="button contact__social-link" rel="noopener" href="https://www.linkedin.com/company/ohzinteractivestudio/" target="_blank" data-track="contact.linkedin"><svg xmlns="http://www.w3.org/2000/svg" width="31.5" height="31.499" viewbox="0 0 31.5 31.499"><path d="M7.051,31.5H.52V10.47H7.051ZM3.782,7.6A3.8,3.8,0,1,1,7.564,3.783,3.814,3.814,0,0,1,3.782,7.6ZM31.493,31.5H24.976V21.263c0-2.44-.049-5.569-3.4-5.569-3.4,0-3.916,2.651-3.916,5.393V31.5H11.142V10.47h6.263v2.869H17.5a6.862,6.862,0,0,1,6.179-3.4c6.609,0,7.824,4.352,7.824,10.005V31.5Z" transform="translate(0 -0.001)" fill="#fff"></path></svg></a></div></div></div></div><div class="hidden our-work section"><div class="our-work__shape"><a class="button our-work__video-group" rel="noopener" href="#" target="_blank" data-track="our_work.video"><video class="our-work__video" autoplay loop playsinline muted></video><video class="our-work__video our-work__video--noise" autoplay loop playsinline muted></video></a><svg class="our-work__shape-svg" viewbox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><polygon class="our-work__shape-polygon" points="0,0 100,0 50,100 50,100" fill="none" stroke="rgb(247, 207, 72)" stroke-width="2px" stroke-linejoin="round"></polygon></svg></div><div class="our-work__title section__title"><div class="section__title-letter">O</div><div class="section__title-letter">U</div><div class="section__title-letter">R</div><div class="section__title-letter">&nbsp;</div><div class="section__title-letter">W</div><div class="section__title-letter">O</div><div class="section__title-letter">R</div><div class="section__title-letter">K</div></div><div class="our-work__description section__description section__description--left"><div class="our-work__description-title section__description-title">HTC VIVERSE</div><div class="our-work__description-text section__description-text">In partnership with HTC we took the challenge of creating a metaverse to showcase a new product yet to be launched, fighting against tight deadlines and high quality expectations.</div><div class="section__description-buttons"><a class="button button__primary our-work__button-primary" rel="noopener" href="https://partners.viverse.com/" target="_blank" data-track="our_work.explore">EXPLORE</a><div class="button button__secondary" onclick="app.our_work_view.next_work()" data-track="our_work.next_work">NEXT WORK<svg width="19" height="12" viewbox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M17.5 6L18.1727 6.73994C18.3811 6.55042 18.5 6.28174 18.5 6C18.5 5.71826 18.3811 5.44958 18.1727 5.26006L17.5 6ZM0 7H17.5V5H0V7ZM18.1727 5.26006L12.6727 0.26006L11.3273 1.73994L16.8273 6.73994L18.1727 5.26006ZM16.8273 5.26006L11.3273 10.2601L12.6727 11.7399L18.1727 6.73994L16.8273 5.26006Z" fill="white"></path> </svg> </div></div></div><div class="our-work__description section__description section__description--right"><div class="our-work__description-title section__description-title">BIOLOGICAL PREPARATIONS</div><div class="our-work__description-text section__description-text">In partnership with RED-FERN, we made their designs a reality.<div class="section__description-space"></div> We created a world where you can learn about bacteria and other biological entities and how they are used by the laboratories.</div><div class="section__description-buttons"><a class="button button__primary our-work__button-primary" rel="noopener" href="https://immersive.biologicalpreparations.com/" target="_blank" data-track="our_work.explore">EXPLORE</a><div class="button button__secondary" onclick="app.our_work_view.next_work()" data-track="our_work.next_work">NEXT WORK<svg width="19" height="12" viewbox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M17.5 6L18.1727 6.73994C18.3811 6.55042 18.5 6.28174 18.5 6C18.5 5.71826 18.3811 5.44958 18.1727 5.26006L17.5 6ZM0 7H17.5V5H0V7ZM18.1727 5.26006L12.6727 0.26006L11.3273 1.73994L16.8273 6.73994L18.1727 5.26006ZM16.8273 5.26006L11.3273 10.2601L12.6727 11.7399L18.1727 6.73994L16.8273 5.26006Z" fill="white"></path> </svg> </div></div></div><div class="our-work__description section__description section__description--left"><div class="our-work__description-title section__description-title">OUR PROJECTS</div><div class="our-work__description-text section__description-text">Here at OHZI we have fun working on our own projects, and we wanted to share them with you.<div class="section__description-space"></div> We welcome you to explore our projects and experiments, and we hope you enjoy them as much as we do!</div><div class="section__description-buttons"><div class="button button__primary our-work__button-primary" onclick="app.internal_projects_modal.show()" data-track="our_work.our_projects">EXPLORE</div><div class="button button__secondary" onclick="app.our_work_view.next_work()" data-track="our_work.next_work">NEXT WORK<svg width="19" height="12" viewbox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M17.5 6L18.1727 6.73994C18.3811 6.55042 18.5 6.28174 18.5 6C18.5 5.71826 18.3811 5.44958 18.1727 5.26006L17.5 6ZM0 7H17.5V5H0V7ZM18.1727 5.26006L12.6727 0.26006L11.3273 1.73994L16.8273 6.73994L18.1727 5.26006ZM16.8273 5.26006L11.3273 10.2601L12.6727 11.7399L18.1727 6.73994L16.8273 5.26006Z" fill="white"></path> </svg> </div></div></div><div class="our-work__description section__description section__description--right"><div class="our-work__description-title section__description-title">SYNDIKAT7</div><div class="our-work__description-text section__description-text">In partnership with SYNDIKAT7, we developed their website as a journey down a dark, foggy New York City alleyway.<div class="section__description-space"></div> The adventure is even complete with glowing neon to guide your way! We especially love how a high-quality product meets awesome performance with this piece.</div><div class="section__description-buttons"><a class="button button__primary our-work__button-primary" rel="noopener" href="https://www.syndikat7.de/" target="_blank" data-track="our_work.explore">EXPLORE</a><div class="button button__secondary" onclick="app.our_work_view.next_work()" data-track="our_work.next_work">NEXT SECTION<svg width="19" height="12" viewbox="0 0 19 12" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M17.5 6L18.1727 6.73994C18.3811 6.55042 18.5 6.28174 18.5 6C18.5 5.71826 18.3811 5.44958 18.1727 5.26006L17.5 6ZM0 7H17.5V5H0V7ZM18.1727 5.26006L12.6727 0.26006L11.3273 1.73994L16.8273 6.73994L18.1727 5.26006ZM16.8273 5.26006L11.3273 10.2601L12.6727 11.7399L18.1727 6.73994L16.8273 5.26006Z" fill="white"></path> </svg> </div></div></div><div class="button button__primary hidden our-work__next-section-button" onclick="app.our_work_view.go_to_next_section()">Contact</div></div><div class="hidden how-we-do-it section"><div class="how-we-do-it__title section__title"><div class="section__title-letter">H</div><div class="section__title-letter">O</div><div class="section__title-letter">W</div><div class="section__title-letter section__title-letter--hidden-mobile">&nbsp;</div><div class="section__title-letter">W</div><div class="section__title-letter">E</div><div class="section__title-letter">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter">D</div><div class="section__title-letter">O</div><div class="section__title-letter">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter">I</div><div class="section__title-letter">T</div></div><div class="how-we-do-it__description section__description section__description--left"><div class="section__description-title">PRECISE, INNOVATIVE CRAFTSMANSHIP.</div><div class="section__description-text">Every OHZI experience begins with specialized technological tools and custom development.<div class="section__description-space"></div>Add our obsessive attention to detail and commitment to excellence, and you get true digital magic:<br>spectacular, one-of-a-kind interactive experiences.</div></div><div class="how-we-do-it__description section__description section__description--right"><div class="section__description-title">CREATIVITY WITHOUT LIMITS.</div><div class="section__description-text">We build your story to fit your specific goals<br>Full websites, plug-in solutions, and complete digital brand experiences all come from our studio.<div class="section__description-space"></div>At OHZI, impossible is not an excuse, it’s what we’re doing next.</div></div><div class="how-we-do-it__description section__description section__description--left"><div class="section__description-title">FULL SERVICE TECHNICAL FLUENCY.</div><div class="section__description-text">Our team speaks complex digital languages with confidence. Here are just a few of our favorite things to do.<div class="section__description-space"></div><div class="section__list"><div class="section__list-group"><div class="section__list-item">- UX & UI Web Experiences Design.</div><div class="section__list-item">- 3D, AR and VR Interactive Web Experiences Development.</div><div class="section__list-item">- WebGL addons and tools for your website.</div></div></div></div></div><div class="button button__primary hidden how-we-do-it__next-section-button" onclick="app.how_we_do_it_view.go_to_next_section()">Our Work</div></div><div class="hidden section who-we-are"><div class="section__title who-we-are__title"><div class="section__title-letter">W</div><div class="section__title-letter">H</div><div class="section__title-letter">O</div><div class="section__title-letter section__title-letter--hidden-mobile">&nbsp;</div><div class="section__title-letter">W</div><div class="section__title-letter">E</div><div class="section__title-letter">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter section__title-letter--hidden-desktop">&nbsp;</div><div class="section__title-letter">A</div><div class="section__title-letter">R</div><div class="section__title-letter">E</div></div><div class="section__description section__description--left who-we-are__description"><div class="section__description-title">WE BELIEVE IN BUILDING THE IMPOSSIBLE.</div><div class="section__description-text">Immersive digital storytelling demands both technical precision and limitless imagination.<div class="section__description-space"></div>We bring both. At OHZI, we tell your story with innovative, exciting tools that blur boundaries: no excuses, only possibilities.</div></div><div class="section__description section__description--right who-we-are__description"><div class="section__description-title">WE BELIEVE IN GLOBAL PARTNERSHIP.</div><div class="section__description-text">The world is our office. We are a passionate, tightly knit team of designers and developers dedicated to building genuine partnerships.<div class="section__description-space"></div>Every project makes a mark on our own story, and we love being a part of helping to tell yours.</div></div><div class="section__description section__description--left who-we-are__description"><div class="section__description-title">WE BELIEVE IN JOY WITHOUT COMPROMISE.</div><div class="section__description-text">We’re here to have a good time, and our audiences do, too.<div class="section__description-space"></div>Our team embraces each story like it's our very first adventure, and you can expect every ounce of our passion as we bring your brand to life.<div class="section__description-space"></div>This is what we love to do.</div></div><div class="button button__primary hidden who-we-are__next-section-button" onclick="app.who_we_are_view.go_to_next_section()">How We Do It</div></div><div class="hidden menu section"><div class="menu__mobile"><div class="menu__mobile-group"></div><div class="menu__mobile-group menu__mobile-group--clickable menu__mobile-title-group" onclick="app.menu_view.go_to(app.sections.WHO_WE_ARE)" data-track="menu.who_we_are"><div class="menu__mobile-pretitle"></div><div class="menu__mobile-title"></div></div><div class="menu__mobile-group"></div><div class="menu__mobile-group menu__mobile-group--clickable" onclick="app.menu_view.go_to(app.sections.WHO_WE_ARE)" data-track="menu.who_we_are"><div class="hidden menu__mobile-drag-icon"><div class="menu__mobile-drag-icon-animation"></div><div class="menu__mobile-drag-icon-text">DRAG TO NAVIGATE</div></div><div class="hidden menu__mobile-click-icon"><div class="menu__mobile-click-icon-animation"></div><div class="menu__mobile-click-icon-text">CLICK TO EXPLORE</div></div></div></div><div class="menu__desktop"><div class="menu__items"><div class="menu__item-bar"></div><div class="menu__desktop-pretitle"></div><div class="button menu__item" data-id="0" onclick="app.menu_view.go_to(app.sections.WHO_WE_ARE)" data-track="menu.who_we_are">WHO WE ARE</div><div class="button menu__item" data-id="1" onclick="app.menu_view.go_to(app.sections.HOW_WE_DO_IT)" data-track="menu.how_we_do_it">HOW WE DO IT</div><div class="button menu__item" data-id="2" onclick="app.menu_view.go_to(app.sections.OUR_WORK)" data-track="menu.our_work">OUR WORK</div><div class="button menu__item" data-id="3" onclick="app.menu_view.go_to(app.sections.CONTACT)" data-track="menu.contact">CONTACT</div></div></div></div><div class="hidden home section"><div class="home__group"></div><div class="home__group home__group--clickable"><div class="home__title">DIVE INTO <span></span><br>DIGITAL MAGIC</div><div class="home__subtitle home__subtitle--1">We bring stories to life <span></span><br>with 3D, AR, and VR. </div><div class="home__subtitle home__subtitle--2">Are you ready to explore <span></span><br>the future with us?</div></div><div class="home__group home__group-button"><div class="button button__primary home__button" onclick="app.go_to(app.sections.MENU, false, false)" data-track="home.explore">EXPLORE</div></div></div><div class="component hidden tap-icon"><div class="button hidden tap-icon__container"><div class="tap-icon__halos"><div class="tap-icon__halo tap-icon__halo--1"></div><div class="tap-icon__halo tap-icon__halo--2"></div><div class="tap-icon__halo tap-icon__halo--3"></div><div class="tap-icon__halo tap-icon__halo--4"></div></div><div class="tap-icon__description">TAP AND HOLD TO PLAY</div></div></div><div class="component hidden scroll-icon"><div class="button hidden scroll-icon__container" onclick="app.scroll.scroll_forward()" data-track="scroll.scroll_forward"><div class="scroll-icon__text">SCROLL TO EXPLORE</div></div></div><div class="component hidden progress-bar"><div class="progress-bar__body"><div class="progress-bar__start"></div><div class="progress-bar__line"><div class="progress-bar__progress-container"><div class="progress-bar__progress"></div></div></div><div class="button progress-bar__end"></div></div></div><div class="component footer hidden"><div class="footer__left"><div class="button hidden volume-icon volume-icon--footer" onclick="app.header_component.volume_icon.toggle_volume()" data-track="footer.toggle_volume"><svg class="volume-icon__svg" alt="Volume" viewbox="0 0 40 40"><path class="footer__volume-icon-path volume-icon__path"></path></svg></div></div><div class="footer__center"></div><div class="footer__right"><a class="button footer__email" href="/cdn-cgi/l/email-protection#563e333a3a3916393e2c3f783f39" onclick="app.contact_view.contact(event)" target="_blank" data-track="footer.email"><div class="footer__email-text"><span class="__cf_email__" data-cfemail="fbb3beb7b7b4bbb4b3a1b2d5b2b4">[email&#160;protected]</span></div><div class="footer__email-icon"><svg width="32" height="21" viewbox="0 0 32 21" fill="none" xmlns="http://www.w3.org/2000/svg"> <path d="M29 1H3C1.89543 1 1 1.89543 1 3V18C1 19.1046 1.89543 20 3 20H29C30.1046 20 31 19.1046 31 18V3C31 1.89543 30.1046 1 29 1Z" stroke="white" stroke-linejoi